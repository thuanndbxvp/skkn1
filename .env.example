# ============================================
# AI Provider Configuration
# ============================================

# Default AI Provider (gemini recommended)
DEFAULT_AI_PROVIDER=gemini

# ============================================
# Google Gemini Configuration (RECOMMENDED)
# ============================================
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# Gemini Model (optional, defaults to gemini-2.0-flash)
# Options: 
#   - gemini-2.0-flash (recommended - fast, efficient)
#   - gemini-2.0-flash-lite (cheapest)
#   - gemini-1.5-flash (balanced)
#   - gemini-1.5-flash-8b (lightweight)
#   - gemini-1.5-pro (highest quality)
GEMINI_MODEL=gemini-2.0-flash

# ============================================
# OpenAI Configuration (Optional)
# ============================================
# Only needed if you want to use OpenAI instead of Gemini
# Get your API key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_MODEL=gpt-4o-mini
